# Sanity (used by frontend + Studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Sanity write client (cron patches siteSettings.exchangeRates)
# Falls back to NEXT_PUBLIC_SANITY_* if unset
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_VERSION=
# Token with write access (also accepts SANITY_API_TOKEN)
SANITY_WRITE_TOKEN=

# Currency rates cron (Vercel cron → /api/cron/update-currency-rates)
FIXER_API_KEY=
CRON_SECRET=

# Optional: site base URL for SEO/structured data
NEXT_PUBLIC_SITE_URL=

# Telegram — agent contact notifications (used when real delivery is wired; see src/lib/notifications/agentContact/)
# Per-agent chat IDs will likely come from Sanity or another mapping; TELEGRAM_AGENT_CONTACT_CHAT_ID is a single optional fallback until then.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_GENERAL_CHAT_ID=
TELEGRAM_AGENT_CONTACT_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Optional: set to "general", "agent", or "both" to force stub failure (local testing only)
# TELEGRAM_DEBUG_STUB_FAIL=