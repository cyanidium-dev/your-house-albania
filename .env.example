# Sanity (used by frontend + Studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Sanity write client (cron patches siteSettings.exchangeRates)
# Falls back to NEXT_PUBLIC_SANITY_* if unset
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_VERSION=
# Token with write access (also accepts SANITY_API_TOKEN)
SANITY_WRITE_TOKEN=

# Currency rates cron (Vercel cron → /api/cron/update-currency-rates)
FIXER_API_KEY=
CRON_SECRET=

# Optional: site base URL for SEO/structured data
NEXT_PUBLIC_SITE_URL=

# Telegram — general contacts (`POST /api/contact-agent`) and register (`POST /api/registration-request`) use TELEGRAM_GENERAL_CHAT_ID
# Required for production: real sendMessage
TELEGRAM_BOT_TOKEN=
TELEGRAM_GENERAL_CHAT_ID=
# Optional: override API host (default https://api.telegram.org)
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Agent-branch stub / future per-agent inbox (not used by general contacts delivery today)
TELEGRAM_AGENT_CONTACT_CHAT_ID=
# Optional: set to "general", "agent", or "both" to force delivery failure (testing; general path skips real send when it triggers)
# TELEGRAM_DEBUG_STUB_FAIL=
# Optional: set to false to disable indexing of the site, false for dev, true for production
NEXT_PUBLIC_ENABLE_INDEXING=false
